# =========================================================================
# Environment variables — Barbearia do Romário landing page
# =========================================================================
# Copy this file to `.env` (local) or configure the same keys in the hosting
# dashboard (Lovable → Project Settings → Environment variables) for prod.
#
# All keys are prefixed with VITE_ so they are exposed to the client bundle.
# Never put private secrets here — this app has no server-side runtime.
# =========================================================================

# --- Monitoring (opcional) -----------------------------------------------
# Sentry DSN. Se vazio, o SDK do Sentry não é carregado (zero custo).
# Crie um projeto React em https://sentry.io e copie o DSN aqui.
VITE_SENTRY_DSN=

# Ambiente reportado ao Sentry (production | preview | development).
VITE_SENTRY_ENV=production

# Release opcional (ex.: SHA do commit) para agrupar issues por deploy.
VITE_SENTRY_RELEASE=

# Amostragem de performance tracing (0.0 a 1.0). 0 desativa tracing.
VITE_SENTRY_TRACES=0

# --- Domínio próprio ------------------------------------------------------
# Domínio canônico do site publicado. Usado para gerar links absolutos,
# sitemap.xml e canonical. Sem barra final.
# Exemplo: https://barbeariadoromario.com.br
VITE_SITE_URL=https://landingpagebarbearia.lovable.app
